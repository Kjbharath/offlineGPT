# ============================================================
# OfflineGPT - Environment Configuration
# ============================================================
# Copy this file to .env and edit the values below.
# All settings are pre-configured with safe defaults for a
# 12GB VRAM NVIDIA GPU.
# ============================================================

# -----------------------------------------------------------
# MODEL SETTINGS
# -----------------------------------------------------------
# The filename of the GGUF model inside the ./models/ folder.
# Example models that work well on 12GB VRAM:
#   - Qwen2.5-7B-Instruct-Q4_K_M.gguf
#   - Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
#   - Mistral-7B-Instruct-v0.3-Q4_K_M.gguf
MODEL_FILE=Qwen2.5-7B-Instruct-Q4_K_M.gguf

# How many tokens of context the model can use in a single
# conversation. Higher = uses more VRAM. 8192 is a good
# balance for 12GB cards.
CONTEXT_SIZE=8192

# How many users can chat at the same time. Each slot uses
# some VRAM. 4 is safe for 12GB.
PARALLEL_SLOTS=4

# -----------------------------------------------------------
# WEB INTERFACE SETTINGS
# -----------------------------------------------------------
# The port users will open in their browser.
# Access: http://<YOUR_SERVER_IP>:3000
PORT=3000

# Allow new users to create accounts?
# Set to "true" during initial team setup.
# Set to "false" AFTER everyone has created their account
# (run: bash scripts/lock_registration.sh)
ENABLE_SIGNUP=true

# A secret key used to secure user sessions.
# CHANGE THIS to any random string of letters and numbers.
# Example: MyS3cretK3y2024!
WEBUI_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# Name displayed in the browser tab and login page.
WEBUI_NAME=OfflineGPT
